
CREATE DATABASE college;


USE college;


CREATE TABLE student(
    rollno INT PRIMARY KEY,
    name VARCHAR(50) NOT NULL,
    branch VARCHAR(50),
    marks INT CHECK(marks<=100),
    age INT
);



INSERT INTO student(rollno,name,branch,marks,age)
VALUES
(1,'Aaron','MCA',85,21),
(2,'Mathew','MBA',90,22),
(3,'Tom','BCA',70,20),
(4,'Anu','MCA',95,23),
(5,'Binu','MBA',60,21);


SELECT * FROM student;


SELECT name,marks
FROM student;



-- Equal
SELECT *
FROM student
WHERE marks=90;

-- Greater than
SELECT *
FROM student
WHERE marks>80;

-- Less than
SELECT *
FROM student
WHERE marks<80;

-- Greater than or equal
SELECT *
FROM student
WHERE marks>=85;

-- Less than or equal
SELECT *
FROM student
WHERE marks<=70;

-- Not equal
SELECT *
FROM student
WHERE branch!='MCA';

-- AND condition
SELECT *
FROM student
WHERE branch='MCA'
AND marks>80;

-- OR condition
SELECT *
FROM student
WHERE branch='MBA'
OR branch='BCA';

-- BETWEEN
SELECT *
FROM student
WHERE marks BETWEEN 70 AND 90;

-- IN operator
SELECT *
FROM student
WHERE branch IN('MCA','MBA');

-- Starts with A
SELECT *
FROM student
WHERE name LIKE 'A%';

-- Ends with n
SELECT *
FROM student
WHERE name LIKE '%n';

-- Contains a
SELECT *
FROM student
WHERE name LIKE '%a%';

-- Second letter a
SELECT *
FROM student
WHERE name LIKE '_a%';


UPDATE student
SET marks=100
WHERE rollno=1;


DELETE FROM student
WHERE rollno=5;


DELETE FROM student;


ALTER TABLE student
ADD phone VARCHAR(15);


ALTER TABLE student
DROP COLUMN phone;


ALTER TABLE student
MODIFY marks FLOAT;

ALTER TABLE student
RENAME COLUMN marks TO total_marks;



-- Ascending order
SELECT *
FROM student
ORDER BY name ASC;

-- Descending order
SELECT *
FROM student
ORDER BY total_marks DESC;


SELECT DISTINCT branch
FROM student;



-- COUNT
SELECT COUNT(*)
FROM student;

-- SUM
SELECT SUM(total_marks)
FROM student;

-- AVG
SELECT AVG(total_marks)
FROM student;

-- MAX
SELECT MAX(total_marks)
FROM student;

-- MIN
SELECT MIN(total_marks)
FROM student;


SELECT name,total_marks
FROM student
WHERE total_marks=
(
    SELECT MAX(total_marks)
    FROM student
);

SELECT branch,COUNT(*)
FROM student
GROUP BY branch;

-- GROUP BY with AVG
SELECT branch,AVG(total_marks)
FROM student
GROUP BY branch;

-- GROUP BY with SUM
SELECT branch,SUM(total_marks)
FROM student
GROUP BY branch;


SELECT branch,COUNT(*)
FROM student
GROUP BY branch
HAVING COUNT(*)>1;


CREATE VIEW high_marks AS
SELECT rollno,name,total_marks
FROM student
WHERE total_marks>80;

-- VIEW DATA
SELECT * FROM high_marks;

-- DROP VIEW
DROP VIEW high_marks;

