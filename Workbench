4️ARMSTRONG NUMBER

Example:
153 → 1³ + 5³ + 3³ = 153

-WITHOUT FUNCTION
SET SERVEROUTPUT ON;

DECLARE
    n NUMBER;
    temp NUMBER;
    rem NUMBER;
    sum1 NUMBER := 0;

BEGIN
    n := &n;

    temp := n;

    WHILE temp > 0 LOOP

        rem := MOD(temp,10);

        sum1 := sum1 + (rem * rem * rem);

        temp := TRUNC(temp/10);

    END LOOP;

    IF sum1 = n THEN
        DBMS_OUTPUT.PUT_LINE('Armstrong Number');
    ELSE
        DBMS_OUTPUT.PUT_LINE('Not Armstrong');
    END IF;

END;
/
-WITH FUNCTION
CREATE OR REPLACE FUNCTION armstrong(n NUMBER)
RETURN NUMBER
IS
    temp NUMBER;
    rem NUMBER;
    sum1 NUMBER := 0;

BEGIN

    temp := n;

    WHILE temp > 0 LOOP

        rem := MOD(temp,10);

        sum1 := sum1 + (rem * rem * rem);

        temp := TRUNC(temp/10);

    END LOOP;

    RETURN sum1;

END;
/
Calling
SET SERVEROUTPUT ON;

DECLARE
    n NUMBER;
    result NUMBER;

BEGIN

    n := &n;

    result := armstrong(n);

    IF result = n THEN
        DBMS_OUTPUT.PUT_LINE('Armstrong Number');
    ELSE
        DBMS_OUTPUT.PUT_LINE('Not Armstrong');
    END IF;

END;
