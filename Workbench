6️ PRIME NUMBER
-WITHOUT FUNCTION
SET SERVEROUTPUT ON;

DECLARE
    n NUMBER;
    i NUMBER;
    flag NUMBER := 0;

BEGIN

    n := &n;

    FOR i IN 2..n-1 LOOP

        IF MOD(n,i)=0 THEN
            flag := 1;
        END IF;

    END LOOP;

    IF flag = 0 THEN
        DBMS_OUTPUT.PUT_LINE('Prime Number');
    ELSE
        DBMS_OUTPUT.PUT_LINE('Not Prime');
    END IF;

END;
/
- WITH FUNCTION
CREATE OR REPLACE FUNCTION prime(n NUMBER)
RETURN NUMBER
IS
    i NUMBER;
    flag NUMBER := 0;

BEGIN

    FOR i IN 2..n-1 LOOP

        IF MOD(n,i)=0 THEN
            flag := 1;
        END IF;

    END LOOP;

    RETURN flag;

END;
/
Calling
SET SERVEROUTPUT ON;

DECLARE
    n NUMBER;
    result NUMBER;

BEGIN

    n := &n;

    result := prime(n);

    IF result = 0 THEN
        DBMS_OUTPUT.PUT_LINE('Prime Number');
    ELSE
        DBMS_OUTPUT.PUT_LINE('Not Prime');
    END IF;

END;
