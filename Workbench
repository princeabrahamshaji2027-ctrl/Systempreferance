3️FACTORIAL PROGRAM
-WITHOUT FUNCTION
SET SERVEROUTPUT ON;

DECLARE
    n NUMBER;
    fact NUMBER := 1;
    i NUMBER;

BEGIN
    n := &n;

    FOR i IN 1..n LOOP
        fact := fact * i;
    END LOOP;

    DBMS_OUTPUT.PUT_LINE('Factorial = ' || fact);

END;
/
- WITH FUNCTION
CREATE OR REPLACE FUNCTION factorial(n NUMBER)
RETURN NUMBER
IS
    fact NUMBER := 1;
    i NUMBER;

BEGIN

    FOR i IN 1..n LOOP
        fact := fact * i;
    END LOOP;

    RETURN fact;

END;
/
Calling
SET SERVEROUTPUT ON;

DECLARE
    result NUMBER;
    n NUMBER;

BEGIN
    n := &n;

    result := factorial(n);

    DBMS_OUTPUT.PUT_LINE('Factorial = ' || result);

END;
