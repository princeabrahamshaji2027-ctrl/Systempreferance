package com.example.calculator;

import android.content.Intent;
import android.os.Bundle;
import android.widget.Button;
import android.widget.EditText;
import android.widget.TextView;

import androidx.activity.EdgeToEdge;
import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {

    EditText n1, n2;
    TextView result;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        EdgeToEdge.enable(this);
        setContentView(R.layout.activity_main);

        n1 = findViewById(R.id.num1);
        n2 = findViewById(R.id.num2);

        Button addbtn = findViewById(R.id.add);
        Button subbtn = findViewById(R.id.sub);
        Button mulbtn = findViewById(R.id.mul);
        Button divbtn = findViewById(R.id.div);
        result = findViewById(R.id.res);




        addbtn.setOnClickListener(v -> calculate("add"));
        subbtn.setOnClickListener(v -> calculate("sub"));
        mulbtn.setOnClickListener(v -> calculate("mul"));
        divbtn.setOnClickListener(v -> calculate("div"));
    }

    private void calculate(String op) {
        String s1 = n1.getText().toString();
        String s2 = n2.getText().toString();

        if (s1.isEmpty() || s2.isEmpty())
            return;

        try {
            int num1 = Integer.parseInt(s1);
            int num2 = Integer.parseInt(s2);
            int res = 0;

            if (op.equals("add"))
                res = num1 + num2;
            else if (op.equals("mul"))
                res = num1 * num2;
            else if (op.equals("sub"))
                res = num1 - num2;
            else if (op.equals("div")) {
                if (num2 != 0) res = num1 / num2;
            }
            result.setText(String.valueOf(res));
        } catch (NumberFormatException e) {
            // Handle invalid input
        }

    }

}




 
