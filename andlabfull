import android.widget.Toast;

import androidx.activity.EdgeToEdge;
import androidx.appcompat.app.AppCompatActivity;
import androidx.core.graphics.Insets;
import androidx.core.view.ViewCompat;
import androidx.core.view.WindowInsetsCompat;

public class MainActivity extends AppCompatActivity {

    DBhelper dBhelper;
    TextView res;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        EdgeToEdge.enable(this);
        setContentView(R.layout.activity_main);

        dBhelper = new DBhelper(this);

        EditText rollno = findViewById(R.id.roll);
        EditText name = findViewById(R.id.name);
        EditText phoneno = findViewById(R.id.phone);
        Button submit = findViewById(R.id.btn);
        Button read = findViewById(R.id.btn2);
        Button update = findViewById(R.id.btn3);
        Button delete = findViewById(R.id.btn4);
        res = findViewById(R.id.view);

        displayData();

        submit.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                String roll = rollno.getText().toString();
                String nameStr = name.getText().toString();
                String mobile = phoneno.getText().toString();

                if (roll.isEmpty() || nameStr.isEmpty() || mobile.isEmpty()) {
                    Toast.makeText(MainActivity.this, "Enter all details", Toast.LENGTH_SHORT).show();
                } else {
                    try {
                        boolean insert = dBhelper.insertStudent(Integer.parseInt(roll), nameStr, mobile);
                        if (insert) {
                            Toast.makeText(MainActivity.this, "Data inserted successfully", Toast.LENGTH_SHORT).show();
                            clearFields(rollno, name, phoneno);
                            displayData();
                        } else {
                            Toast.makeText(MainActivity.this, "Data not inserted", Toast.LENGTH_SHORT).show();
                        }
                    } catch (NumberFormatException e) {
                        Toast.makeText(MainActivity.this, "Invalid roll number", Toast.LENGTH_SHORT).show();
                    }
                }
            }
        });

        read.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                displayData();
                Toast.makeText(MainActivity.this, "Data refreshed", Toast.LENGTH_SHORT).show();
            }
        });

        update.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                String roll = rollno.getText().toString();
                String nameStr = name.getText().toString();
                String mobile = phoneno.getText().toString();

                if (roll.isEmpty() || nameStr.isEmpty() || mobile.isEmpty()) {
                    Toast.makeText(MainActivity.this, "Enter all details to update", Toast.LENGTH_SHORT).show();
                } else {
                    try {
                        boolean isUpdated = dBhelper.updateStudent(Integer.parseInt(roll), nameStr, mobile);
                        if (isUpdated) {
                            Toast.makeText(MainActivity.this, "Data updated successfully", Toast.LENGTH_SHORT).show();
                            clearFields(rollno, name, phoneno);
                            displayData();
                        } else {
                            Toast.makeText(MainActivity.this, "Update failed (Roll No not found)", Toast.LENGTH_SHORT).show();
                        }
                    } catch (NumberFormatException e) {
                        Toast.makeText(MainActivity.this, "Invalid roll number", Toast.LENGTH_SHORT).show();
                    }
                }
            }
        });

        delete.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                String roll = rollno.getText().toString();

                if (roll.isEmpty()) {
                    Toast.makeText(MainActivity.this, "Enter roll no to delete", Toast.LENGTH_SHORT).show();
                } else {
                    try {
                        boolean isDeleted = dBhelper.deleteStudent(Integer.parseInt(roll));
                        if (isDeleted) {
                            Toast.makeText(MainActivity.this, "Data deleted successfully", Toast.LENGTH_SHORT).show();
                            clearFields(rollno, name, phoneno);
                            displayData();
                        } 
      else {
         Toast.makeText(MainActivity.this, "Delete failed (Roll No not found)", Toast.LENGTH_SHORT).show();
                        }
                    } catch (NumberFormatException e) {
                        Toast.makeText(MainActivity.this, "Invalid roll number", Toast.LENGTH_SHORT).show();
                    }
                }
            }
        });
    }

    private void clearFields(EditText r, EditText n, EditText p) {
        r.setText("");
        n.setText("");
        p.setText("");
    }

    private void displayData() {
        Cursor cursor = dBhelper.getAllStudents();
        if (cursor == null) return;
        
        if (cursor.getCount() == 0) {
            res.setText("No data available");
            cursor.close();
            return;
        }

        StringBuilder buffer = new StringBuilder();
        while (cursor.moveToNext()) {
            int roll = cursor.getInt(0);
            String nameStr = cursor.getString(1);
            String mobile = cursor.getString(2);
            buffer.append("Roll: ").append(roll)
                  .append(", Name: ").append(nameStr)
                  .append(", Phone: ").append(mobile).append("\n");
        }




        res.setText(buffer.toString());
        cursor.close();
    }
}


